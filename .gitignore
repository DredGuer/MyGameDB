.DS_Store
Suavegarde de version/

# Données réelles utilisateur — jamais commitées
bdd/*.sqlite
bdd/*.sqlite-journal
bdd/*.sqlite-wal
bdd/*.sqlite-shm
bdd/backups/

# Secrets
.env

# Dépendances / build
node_modules/

# Uploads utilisateur (jaquettes, screenshots) — contenu jamais commité
storage/uploads/covers/*
storage/uploads/screenshots/*
!storage/uploads/covers/.gitkeep
!storage/uploads/screenshots/.gitkeep
