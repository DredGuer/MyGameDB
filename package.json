{
  "name": "mygamedb",
  "version": "1.0.0",
  "private": true,
  "description": "MyGameDB — gestionnaire de collection de jeux vidéo (backend + frontend + scripts)",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "npm run start --workspace=backend",
    "dev": "npm run dev --workspace=backend",
    "init-db": "node scripts/init-db.js",
    "sanitize-db": "node scripts/sanitize-existing-db.js"
  },
  "engines": {
    "node": ">=22"
  }
}
