# Copier ce fichier vers .env (jamais commité) et renseigner les valeurs.

# Port d'écoute du serveur backend (API + WebSocket + fichiers statiques)
PORT=3000

# Chemin du fichier SQLite (dans le conteneur Docker, correspond au volume monté)
DB_PATH=/app/bdd/collection.sqlite

# Dossier de stockage des uploads (jaquettes, screenshots)
UPLOADS_PATH=/app/storage/uploads

# Clés API des fournisseurs LLM (optionnelles — laisser vide si non utilisé).
# Ces clés ne sont JAMAIS stockées en base de données ni renvoyées par l'API :
# elles restent uniquement dans ce fichier, lu par le serveur au moment de l'appel.
LLM_API_KEY_GEMINI=
LLM_API_KEY_CLAUDE=
LLM_API_KEY_OPENAI=
LLM_API_KEY_MISTRAL=

# Synchronisation automatique de la bibliothèque Steam (optionnelle — laisser
# vide pour désactiver). Clé API Steam : https://steamcommunity.com/dev/apikey
# SteamID64 : identifiant numérique à 17 chiffres du compte (pas le pseudo).
# Ces valeurs ne sont JAMAIS stockées en base de données, uniquement lues
# depuis ce fichier au démarrage et au moment de chaque synchronisation.
STEAM_API_KEY=
STEAM_ID=
STEAM_SYNC_INTERVAL_HOURS=6
